{
  "name": "@thockr/backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --watch src/server.ts",
    "build": "tsc",
    "start": "node --env-file=.env server.ts",
    "test": "vitest",
    "db:migrate": "node-pg-migrate up -m migrations --envPath .env --tsx",
    "db:rollback": "node-pg-migrate down -m migrations --envPath .env --tsx",
    "db:create": "node-pg-migrate create -m migrations -j ts --envPath .env"
  },
  "dependencies": {
    "@thockr/shared": "workspace:*",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "resend": "^6.12.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/body-parser": "^1.19.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0",
    "body-parser": "^2.2.2",
    "node-pg-migrate": "^8.0.4",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  }
}
